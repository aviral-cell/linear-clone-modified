{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["vitest.config.frontend.ts"],
      "project": ["vitest.*.ts", "scripts/**/*.mjs", "scripts/**/*.sh"]
    },
    "frontend": {
      "entry": [
        "../candidate-contracts/candidate-frontend-contract.js",
        "test/**/*"
      ],
      "project": ["src/**/*.{js,jsx}", "test/**/*"]
    },
    "backend": {
      "entry": [
        "src/app.js",
        "src/server.js",
        "../candidate-contracts/candidate-backend-contract.js",
        "test/**/*.js"
      ],
      "project": ["src/**/*.js", "test/**/*.js"],
      "ignoreFiles": [
        "src/services/admin/index.js",
        "src/services/auth/index.js",
        "src/services/issue/index.js",
        "src/services/project/index.js",
        "src/services/team/index.js",
        "src/services/user/index.js"
      ]
    }
  },
  "ignoreDependencies": [
    "@testing-library/jest-dom",
    "@testing-library/react",
    "@testing-library/user-event",
    "@vitest/coverage-v8",
    "concurrently",
    "eslint",
    "jest-junit",
    "jsdom",
    "typescript-eslint"
  ]
}
