{
  "name": "workflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "backend": "cd backend && npm start",
    "frontend": "cd frontend && npm start",
    "prestart": "bash setup.sh",
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "seed": "cd backend && node utils/seed.js",
    "test:task1": "cd backend && npm run test:task1",
    "test:task2": "cd backend && npm run test:task2",
    "test:task3": "cd backend && npm run test:task3",
    "test:task6": "cd backend && npm run test:task6"
  },
  "dependencies": {
    "concurrently": "7.6.0"
  }
}

