{
  "name": "workflow-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "bun --watch src/server.js",
    "build": "rm -rf dist && bun build ./src/server.js --target bun --outdir ./dist",
    "start": "bun dist/server.js",
    "seed": "bun src/utils/seed.js",
    "test:db": "node scripts/test-db-connection.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "NODE_OPTIONS=--experimental-vm-modules bunx jest --config jest.config.cjs --runInBand --passWithNoTests",
    "test:junit": "NODE_OPTIONS=--experimental-vm-modules bunx jest --config jest.config.cjs --runInBand --reporters=default --reporters=jest-junit --passWithNoTests",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules bunx jest --config jest.config.cjs --watch --passWithNoTests",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules bunx jest --config jest.config.cjs --runInBand --coverage --passWithNoTests"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "2.8.6",
    "dotenv": "^16.0.3",
    "express": "4.18.2",
    "express-async-errors": "3.1.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.7.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "24.9.1",
    "chai": "^4.4.1",
    "chai-http": "^4.4.0",
    "jest": "29.7.0",
    "jest-junit": "16.0.0",
    "prettier": "^3.8.1"
  }
}
