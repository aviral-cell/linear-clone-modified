{
  "name": "workflow-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "cross-env PORT=8000 BROWSER=none react-scripts start",
    "build": "react-scripts build",
    "eject": "react-scripts eject",
    "format": "prettier \"src/**/*.{js,jsx,ts,tsx,css,md}\" --write",
    "format:check": "prettier \"src/**/*.{js,jsx,ts,tsx,css,md}\" --check"
  },
  "dependencies": {
    "autoprefixer": "^10.4.24",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "react": "18.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.11.1",
    "react-scripts": "5.0.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "prettier": "^3.8.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
