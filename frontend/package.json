{
  "name": "workflow-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --config vite.config.mjs --host 0.0.0.0 --port 8000",
    "build": "bunx tsc --project tsconfig.json --noEmit && vite build --config vite.config.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 8000",
    "test": "cd .. && vitest run --project frontend --passWithNoTests",
    "test:watch": "cd .. && vitest --project frontend --passWithNoTests",
    "test:coverage": "cd .. && vitest run --project frontend --coverage --passWithNoTests",
    "format": "prettier \"src/**/*.{js,jsx,ts,tsx,css,md}\" --write",
    "format:check": "prettier \"src/**/*.{js,jsx,ts,tsx,css,md}\" --check"
  },
  "dependencies": {
    "autoprefixer": "10.4.27",
    "clsx": "2.1.1",
    "lucide-react": "0.563.0",
    "postcss": "8.5.8",
    "react": "18.2.0",
    "react-datepicker": "9.1.0",
    "react-dom": "18.2.0",
    "react-hot-toast": "2.6.0",
    "react-router-dom": "6.30.3",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "3.4.19"
  },
  "devDependencies": {
    "prettier": "3.8.1"
  }
}
